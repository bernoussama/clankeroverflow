{
  "name": "clankeroverflow",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@cloudflare/workers-types": "^4.20251213.0",
      "hono": "^4.8.2",
      "@trpc/server": "^11.7.2",
      "better-auth": "^1.5.6",
      "alchemy": "^0.82.1",
      "wrangler": "^4.54.0",
      "@trpc/client": "^11.7.2",
      "pg": "^8.16.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "bun run scripts/dev-with-postgres.ts",
    "dev:bare": "turbo dev --filter=web --filter=server",
    "dev:all": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "test": "turbo test",
    "db:push": "turbo -F @clankeroverflow/db db:push",
    "db:generate": "turbo -F @clankeroverflow/db db:generate",
    "db:migrate": "turbo -F @clankeroverflow/db db:migrate",
    "deploy": "turbo -F @clankeroverflow/infra deploy",
    "destroy": "turbo -F @clankeroverflow/infra destroy",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@clankeroverflow/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@clankeroverflow/config": "workspace:*",
    "@cloudflare/workers-types": "catalog:",
    "@types/node": "^22.13.14",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "turbo": "^2.6.3",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.5",
  "overrides": {
    "better-auth": "1.5.6",
    "@better-auth/core": "1.5.6"
  }
}
