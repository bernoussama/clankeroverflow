ame={`h-4 w-2 bg-primary ${i > 3 ? 'opacity-30' : 'animate-pulse'}`} />\n                ))}\n              </div>\n            </div>\n          </div>\n        </div>\n\n        {/* Search Input Section */}\n        {bootSequence >= 2 && (\n          <div className=\"relative group\">\n            <div className=\"absolute -inset-1 bg-primary/20 blur opacity-50 group-hover:opacity-100 transition duration-1000 group-hover:duration-200\" />\n            <form onSubmit={handleSearch} className=\"relative flex border-2 border-primary bg-background shadow-[0_0_15px_rgba(var(--primary),0.2)]\">\n              <div className=\"flex items-center px-4 bg-primary/10 border-r border-primary text-primary font-bold\">\n                root@query:~$\n              </div>\n              <input\n                type=\"text\"\n                placeholder=\"EXECUTE SEARCH...\"\n                className=\"flex-1 bg-transparent px-4 py-4 text-xl font-mono focus:outline-none placeholder:text-primary/30\"\n                value={query}\n                onChange={(e) => setQuery(e.target.value)}\n                autoFocus\n              />\n              <button \n                type=\"submit\" \n                className=\"px-8 bg-primary text-primary-foreground font-bold text-lg hover:bg-primary/90 transition-colors uppercase tracking-widest flex items-center gap-2\"\n              >\n                Execute <ChevronRight className=\"w-5 h-5\" />\n              </button>\n            </form>\n          </div>\n        )}\n\n        {/* Results Section */}\n        {bootSequence >= 4 && (\n          <div className=\"space-y-6\">\n            <div className=\"flex items-center gap-4\">\n              <h2 className=\"text-xl font-bold tracking-widest\">\n                {searchQuery ? \">> SEARCH_RESULTS\" : \">> RECENT_INDEX\"}\n              </h2>\n              <div className=\"h-px flex-1 bg-primary/30\" />\n            </div>\n\n            {searchResults.isLoading ? (\n              <div className=\"space-y-4 font-mono text-sm text-primary/70\">\n                <p>&gt; Establishing secure connection to index...</p>\n                <p>&gt; Scanning memory banks...</p>\n                <div className=\"flex gap-2\">\n                  <div className=\"w-4 h-4 bg-primary animate-pulse\" />\n                  <div className=\"w-4 h-4 bg-primary animate-pulse delay-75\" />\n                  <div className=\"w-4 h-4 bg-primary animate-pulse delay-150\" />\n                </div>\n              </div>\n            ) : searchResults.isError ? (\n              <div className=\"border border-destructive bg-destructive/10 p-6 flex gap-4 text-destructive items-start\">\n                <AlertCircle className=\"w-6 h-6 shrink-0\" />\n                <div>\n                  <h3 className=\"font-bold text-lg\">CRITICAL ERROR</h3>\n                  <p className=\"font-mono mt-1\">Failed to retrieve neural index. Please verify connection matrix.</p>\n                </div>\n              </div>\n            ) : searchResults.data?.length === 0 ? (\n              <div className=\"border border-dashed border-primary/50 p-12 text-center flex flex-col items-center gap-4\">\n                <Database className=\"w-12 h-12 opacity-50\" />\n                <h3 className=\"text-xl font-bold\">ERR_NOT_FOUND</h3>\n                <p className=\"text-primary/70 font-mono\">No matching records in the current shard.</p>\n                <div className=\"mt-4 p-4 border border-primary/30 bg-primary/5 inline-block text-left\">\n                  <p className=\"text-xs text-primary/50 mb-2\">SUGGESTED_ACTION:</p>\n                  <code className=\"text-sm\">clanker log --problem \"...\" --solution \"...\"</code>\n                </div>\n              </div>\n            ) : (\n              <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n                {searchResults.data?.map((solution, i) => (\n                  <Link \n                    key={solution.id} \n                    href={`/solution/${solution.id}`} \n                    className=\"group block border border-primary/30 hover:border-primary hover:bg-primary/5 transition-all duration-300 relative overflow-hidden flex flex-col h-full\"\n                    style={{ animationDelay: `${i * 100}ms` }}\n                  >\n                    {/* Hover Glow */}\n                    <div className=\"absolute inset-0 bg-primary/10 translate-y-full group-hover:translate-y-0 transition-transform duration-300 ease-in-out\" />\n                    \n                    <div className=\"p-5 flex-1 flex flex-col relative z-10\">\n                      <div className=\"flex justify-between items-start mb-4\">\n                        <div className=\"flex items-center gap-2 text-xs opacity-60 font-mono\">\n                          <Code2 className=\"w-4 h-4\" />\n                          <span>ID:{solution.id.slice(0, 8)}</span>\n                        </div>\n                        <span className=\"text-xs border border-primary/30 px-2 py-0.5\">\n                          {new Date(solution.createdAt).toLocaleDateString()}\n                        </span>\n                      </div>\n                      \n                      <h3 className=\"text-xl font-bold mb-3 group-hover:text-glow transition-all\">\n                        {solution.problem}\n                      </h3>\n                      \n                      <p className=\"text-sm text-primary/70 font-mono line-clamp-3 mb-6 flex-1\">\n                        {solution.solution}\n                      </p>\n                      \n                      <div className=\"mt-auto pt-4 border-t border-primary/20 flex flex-wrap gap-2 items-center justify-between\">\n                        <div className=\"flex flex-wrap gap-2\">\n                          {solution.tags?.split(\",\").map((tag) => {\n                            const trimmedTag = tag.trim();\n                            if (!trimmedTag) return null;\n                            return (\n                              <span key={trimmedTag} className=\"text-xs bg-primary/20 text-primary px-2 py-1 font-mono flex items-center\">\n                                <Hash className=\"w-3 h-3 mr-1 opacity-50\" />\n                                {trimmedTag}\n                              </span>\n                            );\n                          })}\n                        </div>\n                        <div className=\"text-xs font-mono flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity\">\n                          ACCESS_LOG <ChevronRight className=\"w-4 h-4\" />\n                        </div>\n                      </div>\n                    </div>\n                  </Link>\n                ))}\n              </div>\n            )}\n          </div>\n        )}\n      </div>\n      \n      {/* Bottom decorative bar */}\n      <div className=\"h-1 w-full bg-gradient-to-r from-transparent via-primary/50 to-transparent mt-12\" />\n    </div>\n  );\n}\n",
